{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/project-blueprint-engine/change-tree.schema.json",
  "title": "PBE Change Tree",
  "type": "object",
  "required": ["version", "changes"],
  "properties": {
    "version": { "type": "string" },
    "changes": { "type": "array", "items": { "$ref": "#/$defs/change" } }
  },
  "$defs": {
    "change": {
      "type": "object",
      "required": ["id", "type", "status", "reason", "affectedNodeIds"],
      "properties": {
        "id": { "type": "string" },
        "type": { "enum": ["missing_requirement", "design_correction", "implementation_constraint", "test_gap", "feedback", "scope_change", "risk_discovery"] },
        "status": { "enum": ["proposed", "needs_human_decision", "approved", "rejected", "deferred", "applied", "blocked"] },
        "reason": { "type": "string" },
        "affectedNodeIds": { "type": "array", "items": { "type": "string" } },
        "treeMutation": { "type": "object" },
        "decisionId": { "type": ["string", "null"] }
      }
    }
  }
}
