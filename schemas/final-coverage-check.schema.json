{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/project-blueprint-engine/final-coverage-check.schema.json",
  "title": "Final Coverage Check",
  "type": "object",
  "required": [
    "schemaVersion",
    "requirementCoverage",
    "taskCoverage",
    "verificationCoverage",
    "uiUxCoverage",
    "traceabilityIssues",
    "finalDecision"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "requirementCoverage": { "$ref": "#/$defs/coverageCount" },
    "taskCoverage": { "$ref": "#/$defs/coverageCount" },
    "verificationCoverage": { "$ref": "#/$defs/coverageCount" },
    "uiUxCoverage": {
      "type": "object",
      "properties": {
        "screensRequired": { "type": "integer", "minimum": 0 },
        "screensImplemented": { "type": "integer", "minimum": 0 },
        "statesRequired": { "type": "integer", "minimum": 0 },
        "statesCovered": { "type": "integer", "minimum": 0 },
        "missingStates": { "type": "array", "items": { "type": "string" } },
        "evidenceProvided": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "treeClosureCoverage": {
      "type": "object",
      "properties": {
        "activeCycleId": { "type": "string" },
        "includedProductNodeIds": { "type": "array", "items": { "type": "string" } },
        "includedProjectNodeIds": { "type": "array", "items": { "type": "string" } },
        "includedWorkNodeIds": { "type": "array", "items": { "type": "string" } },
        "includedTestNodeIds": { "type": "array", "items": { "type": "string" } },
        "missingProductToProjectLinks": { "type": "array", "items": { "type": "string" } },
        "missingProjectToWorkLinks": { "type": "array", "items": { "type": "string" } },
        "missingWorkToTestLinks": { "type": "array", "items": { "type": "string" } },
        "missingTestToEvidenceLinks": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "evidenceTreeCoverage": {
      "type": "object",
      "properties": {
        "requiredEvidenceNodeIds": { "type": "array", "items": { "type": "string" } },
        "attachedEvidenceNodeIds": { "type": "array", "items": { "type": "string" } },
        "missingEvidenceNodeIds": { "type": "array", "items": { "type": "string" } },
        "staleEvidenceNodeIds": { "type": "array", "items": { "type": "string" } },
        "invalidatedEvidenceNodeIds": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "impactCoverage": {
      "type": "object",
      "properties": {
        "openImpactNodeIds": { "type": "array", "items": { "type": "string" } },
        "reopenedProductNodeIds": { "type": "array", "items": { "type": "string" } },
        "reopenedWorkNodeIds": { "type": "array", "items": { "type": "string" } },
        "affectedTestNodeIds": { "type": "array", "items": { "type": "string" } },
        "affectedEvidenceNodeIds": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "acceptanceCoverage": {
      "type": "object",
      "properties": {
        "submittedBranchIds": { "type": "array", "items": { "type": "string" } },
        "acceptedBranchIds": { "type": "array", "items": { "type": "string" } },
        "acceptedByUserOnly": { "type": "boolean" },
        "acceptedBranchesWithOpenImpact": { "type": "array", "items": { "type": "string" } },
        "acceptedBranchesWithStaleEvidence": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "traceabilityIssues": {
      "type": "object",
      "properties": {
        "requirementsWithoutTasks": { "type": "array", "items": { "type": "string" } },
        "tasksWithoutVerification": { "type": "array", "items": { "type": "string" } },
        "verificationWithoutEvidence": { "type": "array", "items": { "type": "string" } },
        "uiScreensWithoutEvidence": { "type": "array", "items": { "type": "string" } },
        "productNodesWithoutWork": { "type": "array", "items": { "type": "string" } },
        "workNodesWithoutTests": { "type": "array", "items": { "type": "string" } },
        "testNodesWithoutEvidence": { "type": "array", "items": { "type": "string" } },
        "acceptedNodesWithStaleEvidence": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "finalDecision": {
      "type": "string",
      "enum": ["complete", "continue_working", "blocked"]
    }
  },
  "$defs": {
    "coverageCount": {
      "type": "object",
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "completed": { "type": "integer", "minimum": 0 },
        "deferred": { "type": "integer", "minimum": 0 },
        "outOfScope": { "type": "integer", "minimum": 0 },
        "missing": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
