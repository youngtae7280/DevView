{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/devview/devview-state.schema.json",
  "title": "DevView State",
  "type": "object",
  "required": ["schemaVersion", "stage", "mode", "artifacts"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "projectId": { "type": "string" },
    "stage": {
      "type": "string",
      "enum": [
        "start",
        "product_intake",
        "work_planning",
        "verification_design",
        "execution_planning",
        "execution_pack_ready",
        "execution_pack_running",
        "complete",
        "blocked"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "product_intake",
        "work_planning",
        "verification_design",
        "execution_planning",
        "execution_pack_generation",
        "execution_pack_execution"
      ]
    },
    "currentNodeId": { "type": ["string", "null"] },
    "deliveryStatus": {
      "type": "string",
      "enum": [
        "implemented",
        "draft_created_from_assumptions",
        "waiting_root_confirmation",
        "verified",
        "submitted_for_review",
        "revision_requested",
        "revision_in_progress",
        "revision_verified",
        "accepted"
      ]
    },
    "acceptance": {
      "type": "object",
      "required": ["setBy", "acceptedAt", "acceptanceSource"],
      "properties": {
        "setBy": { "type": "string", "enum": ["user"] },
        "acceptedAt": { "type": "string" },
        "acceptanceSource": {
          "type": "string",
          "enum": ["explicit_user_reply"]
        },
        "reviewGateId": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "artifacts": { "type": "object" },
    "autoflow": { "$ref": "https://local/devview/autoflow-state.schema.json" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "deliveryStatus": { "const": "accepted" }
        },
        "required": ["deliveryStatus"]
      },
      "then": {
        "required": ["acceptance"],
        "properties": {
          "acceptance": {
            "required": ["setBy", "acceptedAt", "acceptanceSource"],
            "properties": {
              "setBy": { "const": "user" },
              "acceptanceSource": { "const": "explicit_user_reply" }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
