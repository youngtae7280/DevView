{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/devview/autoflow-state.schema.json",
  "title": "DevView Autoflow State",
  "type": "object",
  "required": ["schemaVersion", "state", "enabled", "profile", "completedSteps", "deterministicSteps", "humanGates"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "enabled": { "type": "boolean" },
    "profile": {
      "type": "string",
      "enum": ["bypass", "lite", "full"]
    },
    "state": {
      "type": "string",
      "enum": [
        "INIT",
        "WAITING_ROOT_CONFIRMATION",
        "PRODUCT_INTAKE_IN_PROGRESS",
        "PRODUCT_INTAKE_DONE",
        "WAITING_UI_UX_CONFIRM",
        "UI_UX_APPROVED",
        "VISUAL_CONTRACT_READY",
        "WORK_PLANNING_IN_PROGRESS",
        "WORK_PLANNING_DONE",
        "UI_SURFACE_INVENTORY_DONE",
        "VERIFICATION_DESIGN_IN_PROGRESS",
        "VERIFICATION_DESIGN_DONE",
        "WAITING_IMPLEMENTATION_SCOPE",
        "SCOPE_SELECTED",
        "EXECUTION_PACK_READY",
        "EXECUTION_IN_PROGRESS",
        "EXECUTION_PACK_RUN_DONE",
        "VISUAL_AUDIT_DONE",
        "WAITING_REVIEW_RESULT",
        "REVISION_REQUESTED",
        "ACCEPTED",
        "DONE",
        "BLOCKED",
        "RPD_IN_PROGRESS",
        "RPD_DONE",
        "WPD_IN_PROGRESS",
        "WPD_DONE",
        "VD_IN_PROGRESS",
        "VD_DONE",
        "ACEP_READY",
        "ACEP_RUN_DONE"
      ]
    },
    "completedSteps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "currentGate": {
      "type": ["string", "null"],
      "enum": [
        "ui_ux_confirm",
        "root_confirmation",
        "implementation_scope",
        "architecture_runway",
        "review_result",
        "next_slice_decision",
        null
      ]
    },
    "nextStep": { "type": ["string", "null"] },
    "deterministicSteps": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "product_intake",
          "work_planning",
          "visual_reference_intake",
          "design_system_derive",
          "ui_surface_inventory",
          "verification_design",
          "dependency_impact_audit",
          "plan_execution",
          "coverage_audit",
          "ux_audit",
          "generate_execution_pack",
          "run_execution_pack",
          "visual_implementation_audit",
          "rpd",
          "wpd",
          "vd",
          "generate_acep",
          "run_acep"
        ]
      }
    },
    "humanGates": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "ui_ux_confirm",
          "root_confirmation",
          "implementation_scope",
          "architecture_runway",
          "review_result",
          "next_slice_decision"
        ]
      }
    },
    "lastUserAction": {
      "type": ["string", "null"],
      "enum": [
        "approve",
        "approve_root_confirmation",
        "revise",
        "ask",
        "status",
        "continue",
        "stop",
        "select_scope",
        "select_full_scope",
        "mark_deferred",
        "mark_foundation",
        "ask_dependency_impact",
        "start_next_slice",
        "complete_current_slice",
        "complete_project",
        null
      ]
    },
    "lastFailure": {
      "type": ["object", "null"],
      "properties": {
        "failedStep": { "type": "string" },
        "reason": { "type": "string" },
        "downstreamSteps": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "stateHistory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "command", "at"],
        "properties": {
          "from": { "$ref": "#/properties/state" },
          "to": { "$ref": "#/properties/state" },
          "command": { "type": "string" },
          "at": { "type": "string" },
          "actor": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "downstreamOnApprove": { "type": "object" },
    "downstreamOnRevision": { "type": "object" }
  },
  "additionalProperties": true
}
